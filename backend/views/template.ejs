<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= portfolio.title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;700&display=swap" rel="stylesheet">
    <style>
        :root { --primary: #2563eb; --text: #1e293b; --bg: #ffffff; }
        body { font-family: 'Inter', sans-serif; margin: 0; padding: 0; color: var(--text); background: var(--bg); transition: 0.3s; }
        
        /* Theme: Midnight Onyx */
        .theme-modern-dark { --bg: #0f172a; --text: #f8fafc; --primary: #38bdf8; }
        /* Theme: Royal Aesthetic */
        .theme-royal-blue { --bg: #1e1b4b; --text: #e0e7ff; --primary: #fbbf24; }
        /* Theme: Minimalist */
        .theme-minimal-light { --bg: #ffffff; --text: #334155; --primary: #000000; }

        .container { max-width: 900px; margin: 0 auto; padding: 100px 20px; }
        .hero { text-align: center; margin-bottom: 80px; }
        .hero h1 { font-size: 3.5rem; margin-bottom: 10px; color: var(--primary); }
        section { margin-bottom: 60px; }
        h2 { border-left: 4px solid var(--primary); padding-left: 15px; text-transform: uppercase; letter-spacing: 2px; font-size: 1.2rem; }
        .content { font-size: 1.1rem; line-height: 1.8; opacity: 0.9; }
    </style>
</head>
<body class="theme-<%= portfolio.theme %>">
    <div class="container">
        <div class="hero">
            <h1><%= portfolio.title %></h1>
            <p>Generated by PortfolioBuilder</p>
        </div>

        <% portfolio.sections.sort((a, b) => a.order - b.order).forEach(section => { %>
            <section>
                <h2><%= section.type %></h2>
                <div class="content">
                    <%= section.content %>
                </div>
            </section>
        <% }) %>
    </div>
</body>
</html>